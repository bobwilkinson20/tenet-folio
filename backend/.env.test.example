# SnapTrade Test Credentials
# Copy this file to .env.test and fill in with your test account credentials
# These credentials should point to a paper trading account for safe testing

SNAPTRADE_CLIENT_ID=your_client_id
SNAPTRADE_CONSUMER_KEY=your_consumer_key
SNAPTRADE_USER_ID=your_test_user_id
SNAPTRADE_USER_SECRET=your_test_user_secret

# IBKR Flex Web Service Test Credentials
# Generate a Flex Token in IBKR Client Portal (Settings > Flex Web Service Configuration)
# Create a Flex Query with Open Positions, Cash Report, and Trades sections

IBKR_FLEX_TOKEN=your_flex_token
IBKR_FLEX_QUERY_ID=your_query_id

# Coinbase Advanced Trade API Test Credentials
# Create a CDP API key at https://portal.cdp.coinbase.com/access/api
# Use read-only permissions for testing

COINBASE_KEY_FILE=your_key_file_path
COINBASE_API_KEY=your_api_key
COINBASE_API_SECRET=your_api_secret

# Charles Schwab API Test Credentials
# Register at https://developer.schwab.com/ and create an app
# Note: Schwab refresh tokens expire after ~7 days
# OAuth token must be stored in Keychain (run setup_schwab.py)

SCHWAB_APP_KEY=your_app_key
SCHWAB_APP_SECRET=your_app_secret
